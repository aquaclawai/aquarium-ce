{
  "name": "@aquaclawai/aquarium",
  "version": "1.0.6",
  "description": "Aquarium CE - AI agent management platform",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": ["ai", "agent", "management", "openclaw", "cli"],
  "files": ["dist/"],
  "bin": {
    "aquarium": "./dist/cli.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--no-experimental-require-module tsx watch src/index.ce.ts",
    "build": "tsc && cp -r src/data dist/data",
    "start": "NODE_OPTIONS=--no-experimental-require-module node dist/index.ce.js",
    "typecheck": "tsc --noEmit",
    "migrate": "NODE_OPTIONS=--no-experimental-require-module tsx src/db/run-migrations.ts",
    "migrate:make": "knex migrate:make --knexfile src/db/knexfile.ts",
    "prepublishOnly": "npm run build -w @aquarium/shared && npm run build:ce -w @aquarium/web && npm run build && mkdir -p dist/web-dist && cp -r ../web/dist/* dist/web-dist/ && mkdir -p dist/node_modules/@aquarium/shared && cp ../../packages/shared/package.json dist/node_modules/@aquarium/shared/ && cp -r ../../packages/shared/dist dist/node_modules/@aquarium/shared/"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dockerode": "^4.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "better-sqlite3": "^11.0.0",
    "knex": "^3.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.33",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
