# =============================================================================
# OpenClaw Gateway — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# These variables are used by docker-compose.yml and the gateway container.
# =============================================================================

# ---------------------------------------------------------------------------
# Gateway authentication
# ---------------------------------------------------------------------------

# Required: Token for authenticating with the gateway API / Control UI.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ---------------------------------------------------------------------------
# Gateway networking
# ---------------------------------------------------------------------------

# Bind mode for the gateway server.
# Accepts: loopback | lan | tailnet | auto | custom
# "lan" binds to 0.0.0.0 (all interfaces) — use for Docker and Kubernetes.
# "loopback" binds to 127.0.0.1 (localhost only).
# Default: lan
OPENCLAW_GATEWAY_BIND=lan

# Gateway API / Control UI port. Default: 18789
OPENCLAW_GATEWAY_PORT=18789

# Bridge port (used for inter-process communication). Default: 18790
OPENCLAW_BRIDGE_PORT=18790

# ---------------------------------------------------------------------------
# Data directories (host paths for Docker Compose bind mounts)
# ---------------------------------------------------------------------------

# Path to OpenClaw config directory on the host.
# Contains openclaw.json, credentials, agent state.
# In Kubernetes, this is a PVC mount — these vars are not used.
OPENCLAW_CONFIG_DIR=~/.openclaw

# Path to OpenClaw workspace directory on the host.
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# ---------------------------------------------------------------------------
# Docker image
# ---------------------------------------------------------------------------

# Image name and tag. Override for custom registry.
OPENCLAW_IMAGE=openclaw-gateway:2026.2.9

# ---------------------------------------------------------------------------
# Model provider (configure in openclaw.json or via these env vars)
# ---------------------------------------------------------------------------

# Example: OpenAI-compatible provider
# OPENCLAW_MODEL_ID=gpt-4o
# OPENCLAW_MODEL_BASE_URL=https://api.openai.com/v1
# OPENCLAW_MODEL_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Channels — at least one channel (WhatsApp or Telegram) must be configured.
# Configure via these env vars or in openclaw.json.
# ---------------------------------------------------------------------------

# --- Telegram ---
# Bot token from @BotFather. Fully headless — no QR code needed.
# TELEGRAM_BOT_TOKEN=123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# --- WhatsApp ---
# WhatsApp requires interactive QR code login (see README).
# No env var for auth — credentials are stored in the PVC.
# DM policy: pairing | allowlist | open | disabled
# OPENCLAW_WHATSAPP_DM_POLICY=allowlist
# Allowed phone numbers (E.164 format, comma-separated)
# OPENCLAW_WHATSAPP_ALLOW_FROM=+15551234567
