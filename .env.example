# Aquarium CE Configuration
# Copy this file to .env and fill in your values

# --- Required ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Security (generate your own!) ---
JWT_SECRET=change-this-to-a-random-string
ENCRYPTION_KEY=change-this-to-a-32-char-string!

# --- Database (defaults match docker-compose.ce.yml) ---
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=aquarium

# --- Gateway ---
# Docker image for OpenClaw gateway instances
# OPENCLAW_IMAGE=ghcr.io/aquaclawai/openclaw:latest

# --- Optional ---
# CORS_ORIGIN=http://localhost:3001
# PORT=3001
